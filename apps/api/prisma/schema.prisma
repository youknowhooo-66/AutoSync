generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  STOCKIST
  MECHANIC
  FINANCIAL
  ATTENDANT
}

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique
  address   String?
  city      String?
  state     String?
  zipCode   String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches              Branch[]
  users                 User[]
  clients               Client[]
  vehicles              Vehicle[]
  parts                 Part[]
  suppliers             Supplier[]
  serviceOrders         ServiceOrder[]
  financialRecords      FinancialRecord[]
  stocks                Stock[]
  serviceOrderApprovals ServiceOrderApproval[]
}

model Branch {
  id        String    @id @default(uuid())
  companyId String
  name      String
  cnpj      String    @unique
  address   String?
  city      String?
  state     String?
  zipCode   String?
  phone     String?
  email     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company               Company                @relation(fields: [companyId], references: [id])
  users                 User[]
  stocks                Stock[]
  serviceOrders         ServiceOrder[]
  inventoryMovements    InventoryMovement[]
  financialRecords      FinancialRecord[]
  sourceTransfers       InventoryMovement[]    @relation("SourceBranch")
  targetTransfers       InventoryMovement[]    @relation("TargetBranch")
  serviceOrderApprovals ServiceOrderApproval[]
}

model User {
  id        String   @id @default(uuid())
  companyId String
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ATTENDANT)
  branchId  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company              Company                @relation(fields: [companyId], references: [id])
  branch               Branch?                @relation(fields: [branchId], references: [id])
  serviceOrders        ServiceOrder[]         @relation("MechanicOS")
  inventoryMovements   InventoryMovement[]
  auditLogs            AuditLog[]
  requestedApprovals   ServiceOrderApproval[] @relation("ApprovalRequestedBy")
  approvedApprovals    ServiceOrderApproval[] @relation("ApprovalApprovedBy")
  rejectedApprovals    ServiceOrderApproval[] @relation("ApprovalRejectedBy")
  invalidatedApprovals ServiceOrderApproval[] @relation("ApprovalInvalidatedBy")

  technicianServices    OSService[]    @relation("OSServiceTechnician")
  assignedServices      OSService[]    @relation("OSServiceAssignedBy")
  finishedServiceOrders ServiceOrder[] @relation("ServiceOrderFinishedBy")
  startedServices       OSService[]    @relation("OSServiceStartedBy")
  pausedServices        OSService[]    @relation("OSServicePausedBy")
  resumedServices       OSService[]    @relation("OSServiceResumedBy")
  completedServices     OSService[]    @relation("OSServiceCompletedBy")
}

model Client {
  id        String     @id @default(uuid())
  companyId String
  name      String
  document  String? // CPF or CNPJ
  type      ClientType @default(PERSON)
  phone     String?
  whatsapp  String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  email     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
}

enum ClientType {
  PERSON
  COMPANY
}

model Vehicle {
  id        String   @id @default(uuid())
  companyId String
  clientId  String
  plate     String   @unique
  model     String
  brand     String
  year      Int
  chassis   String?
  mileage   Int?
  engine    String?
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id])
  client        Client         @relation(fields: [clientId], references: [id])
  serviceOrders ServiceOrder[]
}

model Part {
  id               String   @id @default(uuid())
  companyId        String
  internalCode     String?  @unique
  manufacturerCode String?
  name             String
  description      String?
  category         String?
  brand            String?
  supplierId       String?
  purchasePrice    Decimal? @db.Decimal(10, 2)
  salePrice        Decimal? @db.Decimal(10, 2)
  price            Decimal? @db.Decimal(10, 2) // alias for salePrice for compat
  minStock         Int      @default(0)
  location         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company            Company             @relation(fields: [companyId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  stocks             Stock[]
  osParts            OSPart[]
  inventoryMovements InventoryMovement[]
}

model Stock {
  id        String   @id @default(uuid())
  companyId String
  partId    String
  branchId  String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  part    Part    @relation(fields: [partId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([partId, branchId])
}

model Supplier {
  id        String   @id @default(uuid())
  companyId String
  name      String
  cnpj      String?  @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  parts   Part[]
}

enum OSStatus {
  OPEN
  IN_PROGRESS
  AWAITING_PARTS
  FINISHED
  CANCELLED
}

model ServiceOrder {
  id              String    @id @default(uuid())
  companyId       String
  number          Int       @unique @default(autoincrement())
  clientId        String
  vehicleId       String
  mechanicId      String?
  branchId        String
  status          OSStatus  @default(OPEN)
  totalParts      Decimal   @default(0) @db.Decimal(10, 2)
  totalServices   Decimal   @default(0) @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  finalValue      Decimal   @default(0) @db.Decimal(10, 2)
  totalValue      Decimal?  @db.Decimal(10, 2) // compat alias
  notes           String?
  finishedAt      DateTime?
  finishedById    String?
  completionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company            Company                @relation(fields: [companyId], references: [id])
  client             Client                 @relation(fields: [clientId], references: [id])
  vehicle            Vehicle                @relation(fields: [vehicleId], references: [id])
  mechanic           User?                  @relation("MechanicOS", fields: [mechanicId], references: [id])
  finishedBy         User?                  @relation("ServiceOrderFinishedBy", fields: [finishedById], references: [id], onDelete: SetNull)
  branch             Branch                 @relation(fields: [branchId], references: [id])
  parts              OSPart[]
  services           OSService[]
  approvals          ServiceOrderApproval[]
  inventoryMovements InventoryMovement[]
  financialRecords   FinancialRecord[]

  @@unique([id, companyId])
  @@index([finishedById])
  @@index([status, finishedAt])
}

model OSPart {
  id               String  @id @default(uuid())
  serviceOrderId   String
  partId           String
  quantity         Int
  consumedQuantity Int     @default(0)
  unitPrice        Decimal @db.Decimal(10, 2)

  serviceOrder ServiceOrder        @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  part         Part                @relation(fields: [partId], references: [id])
  movements    InventoryMovement[]

  @@index([serviceOrderId])
  @@index([partId])
}

enum ServiceExecutionStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

model OSService {
  id             String  @id @default(uuid())
  serviceOrderId String
  name           String
  price          Decimal @db.Decimal(10, 2)

  executionStatus ServiceExecutionStatus @default(PENDING)

  technicianId String?

  assignedAt   DateTime?
  assignedById String?

  startedAt   DateTime?
  startedById String?

  pausedAt    DateTime?
  pausedById  String?
  pauseReason String?

  resumedAt   DateTime?
  resumedById String?

  completedAt     DateTime?
  completedById   String?
  completionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  technician   User?        @relation("OSServiceTechnician", fields: [technicianId], references: [id], onDelete: SetNull)
  assignedBy   User?        @relation("OSServiceAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  startedBy    User?        @relation("OSServiceStartedBy", fields: [startedById], references: [id], onDelete: SetNull)
  pausedBy     User?        @relation("OSServicePausedBy", fields: [pausedById], references: [id], onDelete: SetNull)
  resumedBy    User?        @relation("OSServiceResumedBy", fields: [resumedById], references: [id], onDelete: SetNull)
  completedBy  User?        @relation("OSServiceCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([serviceOrderId, executionStatus])
  @@index([technicianId, executionStatus])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
  RETURN
}

model InventoryMovement {
  id             String       @id @default(uuid())
  partId         String
  branchId       String
  userId         String
  type           MovementType
  quantity       Int
  reason         String?
  sourceBranchId String?
  targetBranchId String?
  createdAt      DateTime     @default(now())

  serviceOrderId String?
  osPartId       String?
  idempotencyKey String? @unique

  part         Part          @relation(fields: [partId], references: [id])
  branch       Branch        @relation(fields: [branchId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
  sourceBranch Branch?       @relation("SourceBranch", fields: [sourceBranchId], references: [id])
  targetBranch Branch?       @relation("TargetBranch", fields: [targetBranchId], references: [id])
  serviceOrder ServiceOrder? @relation(fields: [serviceOrderId], references: [id], onDelete: Restrict)
  osPart       OSPart?       @relation(fields: [osPartId], references: [id], onDelete: Restrict)

  @@index([serviceOrderId])
  @@index([osPartId])
  @@index([branchId, createdAt])
}

enum FinancialType {
  PAYABLE
  RECEIVABLE
}

enum FinancialStatus {
  PENDING
  PAID
  CANCELLED
}

model FinancialRecord {
  id          String          @id @default(uuid())
  companyId   String
  branchId    String
  type        FinancialType
  category    String
  description String?
  amount      Decimal         @db.Decimal(10, 2)
  dueDate     DateTime?
  date        DateTime?
  paymentDate DateTime?
  categoryId  String?
  status      FinancialStatus @default(PENDING)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  serviceOrderId         String?
  serviceOrderApprovalId String?

  serviceOrder         ServiceOrder?         @relation(fields: [serviceOrderId], references: [id], onDelete: Restrict)
  serviceOrderApproval ServiceOrderApproval? @relation(fields: [serviceOrderApprovalId], references: [id], onDelete: Restrict)

  @@unique([id, companyId])
  @@unique([serviceOrderId, serviceOrderApprovalId])
  @@index([serviceOrderApprovalId])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  oldValue   Json?
  newValue   Json?
  ip         String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  INVALIDATED
}

enum ApprovalMethod {
  ASSISTED
  CUSTOMER_PORTAL
  DIGITAL_SIGNATURE
}

model ServiceOrderApproval {
  id             String @id @default(uuid())
  serviceOrderId String
  companyId      String
  branchId       String

  version Int
  status  ApprovalStatus @default(PENDING)

  snapshotVersion Int  @default(1)
  snapshot        Json

  totalParts    Decimal @db.Decimal(12, 2)
  totalServices Decimal @db.Decimal(12, 2)
  discount      Decimal @default(0) @db.Decimal(12, 2)
  finalValue    Decimal @db.Decimal(12, 2)

  approvalMethod ApprovalMethod @default(ASSISTED)

  requestedAt   DateTime @default(now())
  requestedById String

  approvedAt   DateTime?
  approvedById String?

  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?

  invalidatedAt      DateTime?
  invalidatedById    String?
  invalidationReason String?

  customerName     String?
  customerDocument String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrder  ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  company       Company      @relation(fields: [companyId], references: [id])
  branch        Branch       @relation(fields: [branchId], references: [id])
  requestedBy   User         @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedBy    User?        @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])
  rejectedBy    User?        @relation("ApprovalRejectedBy", fields: [rejectedById], references: [id])
  invalidatedBy User?        @relation("ApprovalInvalidatedBy", fields: [invalidatedById], references: [id])

  financialRecords FinancialRecord[]

  @@unique([serviceOrderId, version])
  @@index([companyId, branchId])
  @@index([serviceOrderId, status])
  @@index([requestedAt])
}
